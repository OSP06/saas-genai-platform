# Database
DATABASE_URL=postgresql+asyncpg://kortex:kortex@localhost:5432/kortex

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
MAX_TOKENS=4096

# Ollama (optional fallback — set OLLAMA_ENABLED=true to activate)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Embeddings
# EMBEDDING_BACKEND: "sentence_transformers" (default, free) or "openai" (text-embedding-3-small, paid)
EMBEDDING_BACKEND=sentence_transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# File Storage
# STORAGE_BACKEND: "local" (default) or "s3"
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# S3 (only needed when STORAGE_BACKEND=s3)
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Agent
AGENT_MAX_STEPS=10
AGENT_STEP_TIMEOUT=60

# Analytics / Pricing (gpt-4o rates)
COST_PER_1K_INPUT_TOKENS=0.005
COST_PER_1K_OUTPUT_TOKENS=0.015

# Security
SECRET_KEY=change-this-to-a-secure-random-string-at-least-32-chars
API_KEY_PREFIX=kx_

# App
DEBUG=false
# JSON array of allowed CORS origins
ALLOWED_ORIGINS=["http://localhost:3000"]

# Optional: SerpAPI key for enhanced web search in agent tools
SERPAPI_KEY=
